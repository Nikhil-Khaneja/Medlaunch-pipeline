# Pipeline configuration — copy to .env for local runs
# AWS authentication is handled via AWS CLI (aws configure)

SOURCE_BUCKET=medlaunch-pipeline-nk-raw
SOURCE_PREFIX=raw/
DEST_BUCKET=medlaunch-pipeline-nk-filtered
DEST_PREFIX=filtered/expiring-accreditations/
METADATA_BUCKET=medlaunch-pipeline-nk-filtered
METADATA_PREFIX=run-metadata/
AWS_REGION=us-east-1
EXPIRY_WINDOW_DAYS=180
